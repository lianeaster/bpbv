# Facebook Graph API credentials for fetching group posts
# See FACEBOOK_SETUP.md for step-by-step instructions

# Your Facebook App ID (from developers.facebook.com)
FB_APP_ID=

# Your Facebook App Secret
FB_APP_SECRET=

# Long-lived User Access Token (with groups_access permission)
FB_ACCESS_TOKEN=

# Facebook Group ID
FB_GROUP_ID=918669628322290
